---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				/* let .prose own the horizontal gutters; keep global vertical padding */
				padding-left: 0;
				padding-right: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 1280px;
				max-width: calc(100% - 1rem);
				margin: auto;
				padding: 0 0.25rem;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 2rem;
				padding: 2rem 0 1.5rem;
				text-align: left;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.date {
				font-size: 0.75rem;
				font-weight: 500;
				letter-spacing: 0.06em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin: 0 0 0.6rem;
			}
			.title h1 {
				font-size: 1.65rem;
				font-weight: 700;
				letter-spacing: -0.02em;
				line-height: 1.25;
				margin: 0;
			}
			.last-updated-on {
				font-style: italic;
			}
			.table-scroll {
				overflow-x: auto;
				-webkit-overflow-scrolling: touch;
				margin: 1.25rem 0;
				border-radius: 4px;
			}
			.table-scroll > table {
				margin: 0 !important;
				min-width: 320px;
			}
			.prose svg {
				height: unset;    /* prevent height:auto collapsing SVGs without viewBox to 0 */
				overflow: hidden; /* clip content to element box instead of bleeding over text */
			}
			.table-scroll > svg {
				max-width: none; /* allow SVG to be full-width inside scroll container */
			}
			@media (max-width: 720px) {
				.prose {
					/* slimmer phone gutter (~14px) — reduced from 1.25rem, still not flush to the edge */
					max-width: calc(100% - 0.5rem);
					padding: 0 0.75rem;
				}
				.title {
					padding: 1.5rem 0 1rem;
				}
				.prose figure {
					margin: 1.25rem 0;
					text-align: center;
				}
				.prose figure img {
					max-width: 100% !important;
					width: 100%;
					height: auto;
				}
				.prose figure figcaption {
					text-align: center;
					line-height: 1.4;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
				</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<script>
			function wrapInScroll(el: Element) {
				if (el.parentElement?.classList.contains('table-scroll')) return;
				const wrapper = document.createElement('div');
				wrapper.className = 'table-scroll';
				el.parentNode!.insertBefore(wrapper, el);
				wrapper.appendChild(el);
			}
			document.querySelectorAll('.prose table').forEach(wrapInScroll);
			document.querySelectorAll('.prose svg').forEach((svg) => {
				const w = svg.getAttribute('width');
				const h = svg.getAttribute('height');
				if (w && h && !svg.getAttribute('viewBox')) {
					svg.setAttribute('viewBox', `0 0 ${w} ${h}`);
				}
				if (parseInt(w ?? '0', 10) > 500) wrapInScroll(svg);
			});
		</script>
	</body>
</html>
