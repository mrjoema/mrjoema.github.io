---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION, BASE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .page-label {
        display: block;
        padding: 1.5rem 0 0.75rem;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgb(var(--gray));
        border-bottom: 1px solid rgb(var(--gray-light));
      }
      .filter-tabs {
        display: flex;
        gap: 0.375rem;
        padding: 0.875rem 0;
        border-bottom: 1px solid rgb(var(--gray-light));
        flex-wrap: wrap;
      }
      .filter-tabs button {
        padding: 0.2rem 0.7rem;
        border: 1px solid rgb(var(--gray-light));
        border-radius: 999px;
        background: transparent;
        cursor: pointer;
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: rgb(var(--gray));
      }
      .filter-tabs button.active,
      .filter-tabs button:hover {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
      }
      .post-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .post-item {
        border-bottom: 1px solid rgb(var(--gray-light));
      }
      .post-item[hidden] {
        display: none;
      }
      .post-item a {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 2rem;
        padding: 1rem 0;
        text-decoration: none;
        color: inherit;
      }
      .post-item a:hover .title {
        color: var(--accent);
      }
      .title {
        font-size: 0.875rem;
        font-weight: 450;
        color: rgb(var(--black));
        line-height: 1.4;
      }
      .date {
        font-size: 0.72rem;
        color: rgb(var(--gray));
        white-space: nowrap;
        flex-shrink: 0;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section>
        <span class="page-label">Writing</span>
        <div class="filter-tabs">
          <button class="active" data-filter="all">All</button>
          <button data-filter="article">Article</button>
          <button data-filter="concept">Concept</button>
          <button data-filter="showcase">Showcase</button>
          <button data-filter="experiment">Experiment</button>
        </div>
        <ul class="post-list">
          {posts.map((post) => (
            <li class="post-item" data-type={post.data.type}>
              <a href={`${BASE}blog/${post.id}/`}>
                <span class="title">{post.data.title}</span>
                <span class="date">
                  <FormattedDate date={post.data.pubDate} />
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
    <script>
      const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-tabs button');
      const postItems = document.querySelectorAll<HTMLElement>('.post-item');

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const filter = btn.dataset.filter;
          buttons.forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          postItems.forEach((post) => {
            post.hidden = filter !== 'all' && post.dataset.type !== filter;
          });
        });
      });
    </script>
  </body>
</html>
